# AICC-Lite 环境变量
# 拷贝此文件为 .env (不要提交)

# DeepSeek-V3 API Key (可选,留空使用 fallback 模式)
DEEPSEEK_API_KEY=

# 数据库连接 (默认 SQLite)
DATABASE_URL=sqlite+aiosqlite:///./aicc_lite.db
# 生产 PostgreSQL 示例:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aicc_lite

# 调试模式
DEBUG=true

# CORS (生产应设置具体 origin)
CORS_ORIGINS=*

# Session secret
SECRET_KEY=change-me-in-production
